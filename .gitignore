# Secrets — never commit
.env
.env.*
# but DO track the placeholder template (no real values)
!.env.example

# Python
.venv/
__pycache__/
*.pyc

# Scraped / generated data (keep out of the repo)
data/*.db
data/*.parquet
data/*.csv
*.bak

# Leftover Colab round-trip artifacts (transient)
/classifications_result.csv
/unclassified_posts.csv
tmp/

# Model weights — large, not versioned (the GGUF is built on Colab and registered locally)
*.gguf
models/*.gguf

# ChromaDB evidence vector store (rebuilt from the DB)
data/chroma_evidence/

# OS
.DS_Store

# Exception: the labeled eval set IS tracked (core project benchmark)
!data/claim_eval.csv

# Week-7 image eval: the labels.jsonl benchmark IS tracked, but the screenshot images are
# NOT (they're third-party screenshots — keep binaries/copyright out of the public repo).
data/image_eval/images/
# generated eval scorecard (regenerated each run)
data/image_eval/eval_results.json

# Runtime maintenance artifacts (regenerated by ingestion / Colab pass)
data/eval_history.jsonl
data/health.json
