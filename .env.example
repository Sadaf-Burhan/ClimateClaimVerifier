# Copy this file to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.

# Bluesky (atproto) — create an APP PASSWORD at https://bsky.app/settings/app-passwords
# (an app password, NOT your main account password)
BLUESKY_HANDLE=you.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Admin password for the Maintenance tab (relabel queue + static eval). Choose your own.
ADMIN_PASSWORD=choose-a-strong-password
